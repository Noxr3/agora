# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # never expose to the browser

# ── App ───────────────────────────────────────────────────────────────────────
# Public base URL of this deployment (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Del agent ─────────────────────────────────────────────────────────────────
# Option A: LiteLLM proxy (recommended — supports any model)
# https://docs.litellm.ai/docs/proxy/quick_start
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=no-key

# Option B: OpenAI directly (fallback when LITELLM_BASE_URL is not set)
# OPENAI_API_KEY=sk-...

# Model for Del — any model supported by your LiteLLM proxy, or an OpenAI model
DEMO_AGENT_MODEL=gpt-4o

# ── Cron ─────────────────────────────────────────────────────────────────────
# Shared secret for /api/cron/health-check
# Vercel sends: Authorization: Bearer <CRON_SECRET>
# Leave empty to disable auth (local dev only)
CRON_SECRET=
